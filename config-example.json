    "syslog_tag": "pulseha",
    "mode": "active-passive",
    "quorum_enabled": false,
    "quorum_min_nodes": 2,
    "quorum_majority": true
  },
  "floating_ip_groups": {},
  "nodes": {},
  "plugins": {}
